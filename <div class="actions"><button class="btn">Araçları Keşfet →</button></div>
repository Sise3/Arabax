<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Arabax Premium</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
html,body{width:100%;overflow-x:hidden}
body{font-family:Arial,Helvetica,sans-serif;background:#060606;color:#fff}
a{text-decoration:none;color:inherit}
.header{height:68px;background:#090909;display:flex;align-items:center;justify-content:space-between;padding:0 18px;border-bottom:1px solid #222;position:sticky;top:0;z-index:9}
.logo{display:flex;align-items:center;gap:9px;font-size:20px;font-weight:900;letter-spacing:5px;white-space:nowrap}
.logo b{font-size:38px;color:#d6a928;letter-spacing:0}
.premium{font-size:9px;letter-spacing:0;border:1px solid #d6a928;color:#d6a928;padding:3px 5px;border-radius:4px}
.nav{display:flex;gap:24px;font-weight:700;font-size:14px}
.nav a:first-child{color:#d6a928;border-bottom:2px solid #d6a928;padding-bottom:23px}
.btn{background:linear-gradient(135deg,#f3c65b,#c99325);color:#080808;border:0;border-radius:6px;padding:14px 22px;font-weight:900}
.icons{display:flex;align-items:center;gap:10px}
.circle{width:38px;height:38px;border:1px solid #555;border-radius:50%;display:grid;place-items:center}
.hero{width:100%;padding:64px 18px 0;min-height:560px;background:
linear-gradient(90deg,#060606 0%,rgba(6,6,6,.88) 38%,rgba(6,6,6,.28) 100%),
url('https://images.unsplash.com/photo-1555215695-3004980ad54e?q=90&w=1800&auto=format&fit=crop') center right/cover no-repeat}
.hero-inner{max-width:1120px;margin:0 auto}
.kicker{color:#d6a928;font-size:20px;font-weight:900;margin-bottom:20px}
h1{font-size:60px;line-height:1.04;font-weight:900;letter-spacing:-2px;max-width:570px}
h1 span{display:block;color:#d6a928}
.desc{font-size:20px;line-height:1.65;color:#eee;max-width:500px;margin:24px 0 30px}
.actions{display:flex;gap:18px;margin-bottom:52px}
.ghost{background:#101010;color:white;border:1px solid #d6a928;box-shadow:none}
.search{background:rgba(12,12,12,.94);border:1px solid #252525;border-radius:9px;padding:14px;display:grid;grid-template-columns:repeat(4,1fr) 145px;gap:14px}
.select{height:62px;border:1px solid #2e2e2e;border-radius:7px;display:flex;align-items:center;justify-content:space-between;padding:0 18px;font-size:16px;background:#111}
.select i{color:#d6a928;font-style:normal;margin-right:10px}
.features{margin:20px 0 36px;display:grid;grid-template-columns:repeat(4,1fr);border:1px solid #252525;border-radius:9px;overflow:hidden;background:#111}
.feature{padding:26px 22px;display:flex;gap:16px;border-right:1px solid #252525}
.feature:last-child{border-right:0}
.feature .ico{min-width:52px;width:52px;height:52px;border-radius:50%;border:1px solid #4a3b17;color:#d6a928;display:grid;place-items:center;font-size:24px}
.feature h3{font-size:16px;margin-bottom:8px}
.feature p{color:#c9c9c9;line-height:1.45}
.section{max-width:1120px;margin:0 auto;padding:0 18px 34px}
.title{display:flex;justify-content:space-between;align-items:center;margin:0 0 22px}
.title h2{font-size:24px}
.title a{color:#d6a928;font-weight:800}
.cards{display:grid;grid-template-columns:repeat(4,1fr);gap:22px}
.card{background:#111;border:1px solid #292929;border-radius:8px;overflow:hidden;box-shadow:0 22px 45px #000}
.img{height:210px;position:relative;overflow:hidden}
.img img{width:100%;height:100%;object-fit:cover;display:block;filter:contrast(1.05) saturate(.9)}
.heart{position:absolute;right:13px;top:13px;background:rgba(0,0,0,.55);border:1px solid #777;border-radius:50%;width:34px;height:34px;display:grid;place-items:center}
.info{padding:17px 19px 21px}
.info h3{font-size:19px;margin-bottom:11px}
.meta,.city{color:#ddd;font-size:15px;line-height:1.4}
.price{color:#d6a928;font-size:21px;font-weight:900;margin-top:11px}
.dots{text-align:center;font-size:32px;color:#777;letter-spacing:8px;margin:20px 0}.dots span{color:#d6a928}
.subscribe{max-width:1120px;margin:24px auto;border:1px solid #252525;border-radius:8px;background:#111;padding:30px;display:flex;align-items:center;justify-content:space-between;gap:25px}
.subscribe h3{font-size:20px;margin-bottom:8px}.subscribe p{color:#ddd}
.email{display:flex;gap:12px;min-width:480px}.email input{flex:1;background:#090909;border:1px solid #333;border-radius:6px;color:white;padding:0 20px;font-size:16px}
.footer{border-top:1px solid #222;margin:28px auto 0;padding:34px 18px 46px;display:grid;grid-template-columns:2fr 1fr 1fr 1fr 1.3fr;gap:22px;color:#ccc;max-width:1120px}
.footer h4{color:white;margin-bottom:14px}.footer p,.footer a{display:block;margin:9px 0;color:#bbb}

/* TELEFON DÜZELTMESİ */
@media(max-width:820px){
  .header{height:62px;padding:0 12px}
  .logo{font-size:17px;letter-spacing:4px}
  .logo b{font-size:34px}
  .premium{font-size:8px;padding:2px 4px}
  .nav{display:none}
  .icons{gap:7px}
  .icons .circle{display:none}
  .hero{
    padding:44px 14px 0;
    min-height:auto;
    background:
      linear-gradient(90deg,#060606 0%,rgba(6,6,6,.93) 47%,rgba(6,6,6,.55) 100%),
      url('https://images.unsplash.com/photo-1555215695-3004980ad54e?q=90&w=1200&auto=format&fit=crop') center/cover no-repeat;
  }
  .kicker{font-size:17px;margin-bottom:16px}
  h1{font-size:39px;letter-spacing:-1px;max-width:100%}
  .desc{font-size:17px;line-height:1.55;margin:20px 0 24px;max-width:100%}
  .actions{gap:12px;margin-bottom:28px}
  .actions .btn{flex:1;padding:14px 8px;font-size:14px}
  .search{grid-template-columns:1fr;gap:10px;padding:10px}
  .select{height:56px;font-size:16px}
  .features{grid-template-columns:1fr;margin:14px 0 28px}
  .feature{border-right:0;border-bottom:1px solid #252525;padding:18px}
  .feature:last-child{border-bottom:0}
  .section{padding:0 14px 28px}
  .title h2{font-size:21px}
  .cards{grid-template-columns:1fr 1fr;gap:14px}
  .img{height:150px}
  .info{padding:13px}
  .info h3{font-size:16px}
  .meta,.city{font-size:13px}
  .price{font-size:17px}
  .subscribe{margin:22px 14px;padding:20px;display:block}
  .email{min-width:0;margin-top:16px;display:grid;grid-template-columns:1fr}
  .email input{height:50px}
  .footer{grid-template-columns:1fr 1fr;padding:28px 14px;gap:18px}
  .footer>div:first-child{grid-column:1/-1}
}

@media(max-width:420px){
  .cards{grid-template-columns:1fr}
  .img{height:210px}
  h1{font-size:36px}
}
</style>
</head>
<body>
<header class="header">
  <div class="logo"><b>A</b>ARABAX <span class="premium">PREMIUM</span></div>
  <nav class="nav"><a>Ana Sayfa</a><a>İlanlar</a><a>Markalar</a><a>Blog</a><a>Hakkımızda</a><a>İletişim</a></nav>
  <div class="icons"><div class="circle">♡</div><div class="circle">♙</div></div>
</header>

<section class="hero">
<div class="hero-inner">
  <div class="kicker">PREMIUM ARAÇ DENEYİMİ</div>
  <h1>ARADIĞIN ARAÇ <span>BURADA.</span></h1>
  <p class="desc">Güvenilir ilanlar, en iyi fiyatlar ve hayalindeki araca giden en hızlı yol.</p>
  <div class="actions"><button class="btn">Araçları Keşfet →</button><button class="btn ghost">İlan Ver +</button></div>

  <div class="search">
    <div class="select"><span><i>▱</i>Tüm Markalar</span><span>⌄</span></div>
    <div class="select"><span><i>▦</i>Tüm Modeller</span><span>⌄</span></div>
    <div class="select"><span><i>⌖</i>Tüm İller</span><span>⌄</span></div>
    <div class="select"><span><i>₺</i>Fiyat Aralığı</span><span>⌄</span></div>
    <button class="btn">⌕ Ara</button>
  </div>

  <div class="features">
    <div class="feature"><div class="ico">♢</div><div><h3>Güvenli Alışveriş</h3><p>İlanlar kontrol edilir.</p></div></div>
    <div class="feature"><div class="ico">✺</div><div><h3>Kaliteli İlanlar</h3><p>Doğru ve güncel bilgiler.</p></div></div>
    <div class="feature"><div class="ico">☏</div><div><h3>7/24 Destek</h3><p>Her zaman yanınızdayız.</p></div></div>
    <div class="feature"><div class="ico">◇</div><div><h3>En İyi Fiyatlar</h3><p>Piyasadaki en uygun ilanlar.</p></div></div>
  </div>
</div>
</section>

<section class="section">
  <div class="title"><h2>ÖNE ÇIKAN İLANLAR</h2><a>Tümünü Gör →</a></div>
  <div class="cards">
    <div class="card"><div class="img"><img src="https://images.unsplash.com/photo-1542362567-b07e54358753?q=90&w=900&auto=format&fit=crop"><span class="heart">♡</span></div><div class="info"><h3>Audi A5</h3><div class="meta">2021 • 45.000 km</div><div class="city">İstanbul</div><div class="price">2.350.000 TL</div></div></div>
    <div class="card"><div class="img"><img src="https://images.unsplash.com/photo-1503376780353-7e6692767b70?q=90&w=900&auto=format&fit=crop"><span class="heart">♡</span></div><div class="info"><h3>Mercedes C-Serisi</h3><div class="meta">2020 • 60.000 km</div><div class="city">Ankara</div><div class="price">2.150.000 TL</div></div></div>
    <div class="card"><div class="img"><img src="https://images.unsplash.com/photo-1555215695-3004980ad54e?q=90&w=900&auto=format&fit=crop"><span class="heart">♡</span></div><div class="info"><h3>BMW 3 Serisi</h3><div class="meta">2022 • 30.000 km</div><div class="city">İzmir</div><div class="price">3.150.000 TL</div></div></div>
    <div class="card"><div class="img"><img src="https://images.unsplash.com/photo-1617814076367-b759c7d7e738?q=90&w=900&auto=format&fit=crop"><span class="heart">♡</span></div><div class="info"><h3>Volkswagen Golf</h3><div class="meta">2019 • 85.000 km</div><div class="city">Bursa</div><div class="price">1.250.000 TL</div></div></div>
  </div>
  <div class="dots"><span>•</span> • •</div>
</section>

<section class="subscribe">
  <div><h3>Yeni ilanlardan haberdar olun</h3><p>E-posta adresinizi bırakın, yeni ilanları kaçırmayın.</p></div>
  <div class="email"><input placeholder="E-posta adresiniz"><button class="btn">Abone Ol</button></div>
</section>

<footer class="footer">
  <div><div class="logo"><b>A</b>ARABAX <span class="premium">PREMIUM</span></div><p>Türkiye’nin en güvenilir araç ilan platformu.</p></div>
  <div><h4>KURUMSAL</h4><a>Hakkımızda</a><a>İletişim</a><a>Kariyer</a></div>
  <div><h4>DESTEK</h4><a>Yardım Merkezi</a><a>Güvenlik İpuçları</a></div>
  <div><h4>YASAL</h4><a>Kullanım Şartları</a><a>KVKK</a></div>
  <div><p>© 2026 Arabax<br>Tüm hakları saklıdır.</p></div>
</footer>
</body>
</html>
